model AwradBook {
  id            String   @id @default(uuid())
  title         String   @unique
  author        String
  coverImageUrl String?
  chapters      AwradChapter[]
}

model AwradChapter {
  id        String   @id @default(uuid())
  bookId    String
  title     String
  audioUrl  String?
  order     Int
  book      AwradBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  lines     AwradLine[]
}

model AwradLine {
  id               String   @id @default(uuid())
  chapterId        String
  arabicText       String
  transliteration  String?
  translation      String?
  order            Int
  chapter          AwradChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}
model Dua {
  id              String   @id @default(uuid())
  title         String   @unique
  arabic          String
  transliteration String
  translation     String
  tags            String[]
  repeatCount     Int      @default(1)
  audioUrl        String?
}
enum GroupVisibility {
  PUBLIC
  PRIVATE
}

enum GroupMemberRole {
  ADMIN
  MEMBER
}

enum CampaignType {
  DHIKR
  KHATM
}

enum KhatmJuzStatus {
  OPEN
  READING
  COMPLETED
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  visibility  GroupVisibility
  inviteCode  String? @unique
  adminId     String
  createdAt   DateTime @default(now())
  members     GroupMember[]
  campaigns   Campaign[]
  admin       User     @relation("GroupAdmin", fields: [adminId], references: [id])
}

model GroupMember {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  role      GroupMemberRole @default(MEMBER)
  joinedAt  DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([groupId])
}

model Campaign {
  id           String   @id @default(cuid())
  groupId      String
  type         CampaignType
  title        String
  targetCount  Int
  currentCount Int @default(0)
  status       String @default("OPEN")
  group        Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  khatmJuz     KhatmJuz[]
  dhikrContributions DhikrContribution[]
}

model KhatmJuz {
  id               String   @id @default(cuid())
  campaignId       String
  juzNumber        Int
  claimedByUserId  String?
  status           KhatmJuzStatus @default(OPEN)
  claimedAt        DateTime?
  completedAt      DateTime?
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  claimedByUser    User?    @relation(fields: [claimedByUserId], references: [id])
}

model DhikrContribution {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  count      Int
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([campaignId])
}
model PDFBook {
  id          String   @id @default(cuid())
  title       String
  author      String?
  description String?
  pdfData     Bytes
  filename    String
  uploadedAt  DateTime @default(now())
}

model SponsoredBanner {
  id           String    @id @default(cuid())
  businessName String
  imageUrl     String
  targetUrl    String?
  description  String?
  monthlyRate  Float?    // ZAR per month, for invoicing reference
  isActive     Boolean   @default(true)
  startsAt     DateTime?
  expiresAt    DateTime?
  views        Int       @default(0)
  clicks       Int       @default(0)
  createdAt    DateTime  @default(now())
}

model VideoPlaylist {
  id                String   @id @default(cuid())
  title             String
  instructor        String
  youtubePlaylistId String
  thumbnailUrl      String
  category          String   @default("General")
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SCHOLAR
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  username String? @unique
  displayName String?
  password String
  createdAt DateTime @default(now())
  dhikrCount Int @default(0)
  currentStreak Int @default(0)
  totalDaysActive Int @default(0)
  coursesCompleted Int @default(0)
  emailVerified Boolean @default(false)
  verificationToken String?
  verificationTokenExpires DateTime?
  role     UserRole  @default(USER)
  bookmarks Bookmark[]
  sessionParticipants SessionParticipant[]
  answers Answer[] @relation("ScholarAnswers")
  questions Question[]
  groupsAdmin Group[] @relation("GroupAdmin")
  groupMemberships GroupMember[]
  claimedJuz KhatmJuz[]
  dhikrContributions DhikrContribution[]
  defaultMadresahId String?
  // Madresah relations
  madresahAdmin       Madresah[]           @relation("MadresahAdmin")
  madresahMembers     MadresahMember[]
  taughtClasses       MadresahClass[]      @relation("ClassTeacher")
  classEnrollments    ClassEnrollment[]
  homeworkSubmissions HomeworkSubmission[]
  homeworkComments    HomeworkComment[]
  studentGrades       Grade[]              @relation("StudentGrades")
  teacherGrades       Grade[]              @relation("TeacherGrades")
  hifzProgress        HifzProgress[]
  struggleReports     StruggleReport[]
  attendanceRecords   Attendance[]
  announcements       ClassAnnouncement[]
  classResources      ClassResource[]
  studentBadges       StudentBadge[]       @relation("BadgeStudent")
  awardedBadges       StudentBadge[]       @relation("BadgeAwarder")
  arabicLearningProgress ArabicLearningProgress?
  arabicAssignmentsCreated ArabicLearningAssignment[] @relation("ArabicAssignmentCreator")
  arabicAssignmentsTargeted ArabicLearningAssignment[] @relation("ArabicAssignmentTargetUser")
}

enum LiveSessionType {
  DHIKR
  YASEEN
  KHATM
}

enum LiveSessionStatus {
  OPEN
  ACTIVE
  COMPLETED
}

model LiveSession {
  id           String   @id @default(uuid())
  type         LiveSessionType
  title        String
  targetCount  Int
  currentCount Int @default(0)
  status       LiveSessionStatus @default(OPEN)
  participants SessionParticipant[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SessionParticipant {
  id           String   @id @default(cuid())
  userId       String
  sessionId    String
  joinedAt     DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
  session      LiveSession @relation(fields: [sessionId], references: [id])
}

model Question {
  id         String   @id @default(cuid())
  userId     String
  content    String
  isAnswered Boolean @default(false)
  createdAt  DateTime @default(now())
  answers    Answer[]

  user       User     @relation(fields: [userId], references: [id])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  scholarId  String
  content    String
  createdAt  DateTime @default(now())

  question   Question @relation(fields: [questionId], references: [id])
  scholar    User     @relation("ScholarAnswers", fields: [scholarId], references: [id])
}

model QuranMedia {
  id              String   @id @default(uuid())
  title           String
  type            String
  url             String
  thumbnailUrl    String?
  reciter         String?
  surahNumber     Int?
  ayahStart       Int?
  ayahEnd         Int?
  language        String?
  durationSeconds Int?
  tags            String[]
  source          String?
  license         String?
  notes           String?
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LearningResource {
  id            String   @id @default(cuid())
  title         String
  description   String?
  type          String
  url           String
  coverImageUrl String?
  author        String?
  language      String?
  pageCount     Int?
  tags          String[]
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LearningQuestion {
  id             String   @id @default(cuid())
  userId         String
  userName       String
  question       String
  aiAnswer       String?
  approvedAnswer String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  }

model HalalFoodItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  isHalal     Boolean @default(true)
  source      String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Book {
  id            String   @id @default(cuid())
  title         String
  author        String
  coverImageUrl String
  pdfFileUrl    String
  category      String
  createdAt     DateTime @default(now())
  bookmarks     Bookmark[]
}

model Recipe {
  id           String   @id @default(cuid())
  title        String
  description  String
  imageUrl     String
  ingredients  Json     // Array of strings
  instructions Json     // Array of strings
  prepTime     String
  createdAt    DateTime @default(now())
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  bookId     String
  pageNumber Int
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@index([userId])
  @@index([bookId])
}

// ─── Madresah (Muslim School) Engine ─────────────────────────────────────────

enum MadresahMemberRole {
  PRINCIPAL
  TEACHER
  STUDENT
  PARENT
}

enum HomeworkStatus {
  OPEN
  SUBMITTED
  GRADED
  OVERDUE
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  LATE
}

model Madresah {
  id          String   @id @default(cuid())
  name        String
  description String?
  address     String?
  phone       String?
  email       String?
  logoUrl     String?
  inviteCode  String   @unique
  adminId     String
  createdAt   DateTime @default(now())
  admin       User     @relation("MadresahAdmin", fields: [adminId], references: [id])
  members     MadresahMember[]
  classes     MadresahClass[]
}

model MadresahMember {
  id         String             @id @default(cuid())
  userId     String
  madresahId String
  role       MadresahMemberRole @default(STUDENT)
  joinedAt   DateTime           @default(now())
  madresah   Madresah           @relation(fields: [madresahId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id])

  @@unique([userId, madresahId])
  @@index([userId])
  @@index([madresahId])
}

model MadresahClass {
  id          String    @id @default(cuid())
  madresahId  String
  name        String
  description String?
  teacherId   String
  createdAt   DateTime  @default(now())
  madresah    Madresah  @relation(fields: [madresahId], references: [id], onDelete: Cascade)
  teacher     User      @relation("ClassTeacher", fields: [teacherId], references: [id])
  students    ClassEnrollment[]
  subjects    Subject[]
  homework    Homework[]
  attendance  Attendance[]
  hifzProgress HifzProgress[]
  struggleReports StruggleReport[]
  announcements   ClassAnnouncement[]
  resources       ClassResource[]
  badges          StudentBadge[]
  arabicAssignments ArabicLearningAssignment[]
}

model ClassEnrollment {
  id         String        @id @default(cuid())
  classId    String
  userId     String
  enrolledAt DateTime      @default(now())
  class      MadresahClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id])

  @@unique([classId, userId])
  @@index([userId])
  @@index([classId])
}

model Subject {
  id       String        @id @default(cuid())
  classId  String
  name     String
  class    MadresahClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  homework Homework[]
  grades   Grade[]

  @@index([classId])
}

model Homework {
  id             String        @id @default(cuid())
  classId        String
  subjectId      String?
  title          String
  description    String
  dueDate        DateTime
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime      @default(now())
  class          MadresahClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject        Subject?      @relation(fields: [subjectId], references: [id])
  submissions    HomeworkSubmission[]
  comments       HomeworkComment[]

  @@index([classId])
}

model HomeworkSubmission {
  id          String           @id @default(cuid())
  homeworkId  String
  studentId   String
  content     String?
  submittedAt DateTime         @default(now())
  status      SubmissionStatus @default(SUBMITTED)
  grade       Int?
  feedback    String?
  homework    Homework         @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student     User             @relation(fields: [studentId], references: [id])

  @@unique([homeworkId, studentId])
  @@index([studentId])
  @@index([homeworkId])
}

model HomeworkComment {
  id         String   @id @default(cuid())
  homeworkId String
  userId     String
  content    String
  isTeacher  Boolean  @default(false)
  createdAt  DateTime @default(now())
  homework   Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@index([homeworkId])
  @@index([userId])
}

model Grade {
  id        String   @id @default(cuid())
  subjectId String
  studentId String
  teacherId String
  value     Float
  maxValue  Float    @default(100)
  label     String?
  createdAt DateTime @default(now())
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  student   User     @relation("StudentGrades", fields: [studentId], references: [id])
  teacher   User     @relation("TeacherGrades", fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([subjectId])
}

model HifzProgress {
  id          String        @id @default(cuid())
  studentId   String
  classId     String
  surahNumber Int
  surahName   String
  ayahFrom    Int           @default(1)
  ayahTo      Int
  memorized   Boolean       @default(false)
  quality     Int?
  notes       String?
  recordedAt  DateTime      @default(now())
  student     User          @relation(fields: [studentId], references: [id])
  class       MadresahClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([classId])
}

model StruggleReport {
  id          String        @id @default(cuid())
  studentId   String
  classId     String
  subjectName String
  topic       String
  description String?
  isResolved  Boolean       @default(false)
  teacherNote String?
  createdAt   DateTime      @default(now())
  student     User          @relation(fields: [studentId], references: [id])
  class       MadresahClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([classId])
}

model Attendance {
  id        String        @id @default(cuid())
  classId   String
  studentId String
  date      DateTime
  present   Boolean       @default(true)
  notes     String?
  class     MadresahClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User          @relation(fields: [studentId], references: [id])

  @@unique([classId, studentId, date])
  @@index([classId])
  @@index([studentId])
}

model ClassAnnouncement {
  id        String        @id @default(cuid())
  classId   String
  authorId  String
  title     String
  content   String
  isPinned  Boolean       @default(false)
  createdAt DateTime      @default(now())
  class     MadresahClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id])

  @@index([classId])
}

model ClassResource {
  id          String        @id @default(cuid())
  classId     String
  authorId    String
  title       String
  description String?
  fileUrl     String?
  fileType    String?
  subjectName String?
  createdAt   DateTime      @default(now())
  class       MadresahClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  author      User          @relation(fields: [authorId], references: [id])

  @@index([classId])
}

model StudentBadge {
  id          String        @id @default(cuid())
  studentId   String
  classId     String
  awardedById String
  type        String
  label       String
  description String?
  awardedAt   DateTime      @default(now())
  student     User          @relation("BadgeStudent", fields: [studentId], references: [id])
  class       MadresahClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  awardedBy   User          @relation("BadgeAwarder", fields: [awardedById], references: [id])

  @@index([studentId])
  @@index([classId])
}

model ArabicLearningProgress {
  id                 String   @id @default(cuid())
  userId             String   @unique
  completedLessons   String[]
  xp                 Int      @default(0)
  streak             Int      @default(0)
  gamesWon           Int      @default(0)
  placementCompleted Boolean  @default(false)
  lastActiveDate     DateTime?
  dailyMinutes       Int      @default(25)
  daysPerWeek        Int      @default(5)
  journalEntry       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ArabicLearningAssignment {
  id               String        @id @default(cuid())
  createdById      String
  targetUserId     String?
  targetClassId    String?
  title            String
  focusArea        String?
  notes            String?
  dueDate          DateTime?
  recommendedMinutes Int        @default(25)
  daysPerWeek      Int           @default(5)
  isCompleted      Boolean       @default(false)
  completedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  createdBy        User          @relation("ArabicAssignmentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  targetUser       User?         @relation("ArabicAssignmentTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetClass      MadresahClass? @relation(fields: [targetClassId], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@index([targetUserId])
  @@index([targetClassId])
  @@index([isCompleted])
}
