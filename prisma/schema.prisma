generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  createdAt DateTime @default(now())
  dhikrCount Int @default(0)
  currentStreak Int @default(0)
  totalDaysActive Int @default(0)
  coursesCompleted Int @default(0)
  emailVerified Boolean @default(false)
  verificationToken String?
  verificationTokenExpires DateTime?
  role     String  @default("user")
  bookmarks Bookmark[]
}

model QuranMedia {
  id              String   @id @default(cuid())
  title           String
  type            String
  url             String
  thumbnailUrl    String?
  reciter         String?
  surahNumber     Int?
  ayahStart       Int?
  ayahEnd         Int?
  language        String?
  durationSeconds Int?
  tags            String[]
  source          String?
  license         String?
  notes           String?
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LearningResource {
  id            String   @id @default(cuid())
  title         String
  description   String?
  type          String
  url           String
  coverImageUrl String?
  author        String?
  language      String?
  pageCount     Int?
  tags          String[]
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LearningQuestion {
  id             String   @id @default(cuid())
  userId         String
  userName       String
  question       String
  aiAnswer       String?
  approvedAnswer String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model HalalFoodItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  isHalal     Boolean @default(true)
  source      String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Book {
  id            String   @id @default(cuid())
  title         String
  author        String
  coverImageUrl String
  pdfFileUrl    String
  category      String
  createdAt     DateTime @default(now())
  bookmarks     Bookmark[]
}

model Recipe {
  id           String   @id @default(cuid())
  title        String
  description  String
  imageUrl     String
  ingredients  Json     // Array of strings
  instructions Json     // Array of strings
  prepTime     String
  createdAt    DateTime @default(now())
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  bookId     String
  pageNumber Int
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])
}
