model AwradBook {
  id            String   @id @default(uuid())
  title         String   @unique
  author        String
  coverImageUrl String?
  chapters      AwradChapter[]
}

model AwradChapter {
  id        String   @id @default(uuid())
  bookId    String
  title     String
  audioUrl  String?
  order     Int
  book      AwradBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  lines     AwradLine[]
}

model AwradLine {
  id               String   @id @default(uuid())
  chapterId        String
  arabicText       String
  transliteration  String?
  translation      String?
  order            Int
  chapter          AwradChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}
model Dua {
  id              String   @id @default(uuid())
  title         String   @unique
  arabic          String
  transliteration String
  translation     String
  tags            String[]
  repeatCount     Int      @default(1)
  audioUrl        String?
}
enum GroupVisibility {
  PUBLIC
  PRIVATE
}

enum GroupMemberRole {
  ADMIN
  MEMBER
}

enum CampaignType {
  DHIKR
  KHATM
}

enum KhatmJuzStatus {
  OPEN
  READING
  COMPLETED
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  visibility  GroupVisibility
  inviteCode  String? @unique
  adminId     String
  createdAt   DateTime @default(now())
  members     GroupMember[]
  campaigns   Campaign[]
  admin       User     @relation("GroupAdmin", fields: [adminId], references: [id])
}

model GroupMember {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  role      GroupMemberRole @default(MEMBER)
  joinedAt  DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Campaign {
  id           String   @id @default(cuid())
  groupId      String
  type         CampaignType
  title        String
  targetCount  Int
  currentCount Int @default(0)
  status       String @default("OPEN")
  group        Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  khatmJuz     KhatmJuz[]
  dhikrContributions DhikrContribution[]
}

model KhatmJuz {
  id               String   @id @default(cuid())
  campaignId       String
  juzNumber        Int
  claimedByUserId  String?
  status           KhatmJuzStatus @default(OPEN)
  claimedAt        DateTime?
  completedAt      DateTime?
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  claimedByUser    User?    @relation(fields: [claimedByUserId], references: [id])
}

model DhikrContribution {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  count      Int
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])
}
model PDFBook {
  id          String   @id @default(cuid())
  title       String
  author      String?
  description String?
  pdfData     Bytes
  filename    String
  uploadedAt  DateTime @default(now())
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SCHOLAR
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  username String? @unique
  displayName String?
  password String
  createdAt DateTime @default(now())
  dhikrCount Int @default(0)
  currentStreak Int @default(0)
  totalDaysActive Int @default(0)
  coursesCompleted Int @default(0)
  emailVerified Boolean @default(false)
  verificationToken String?
  verificationTokenExpires DateTime?
  role     UserRole  @default(USER)
  bookmarks Bookmark[]
  sessionParticipants SessionParticipant[]
  answers Answer[] @relation("ScholarAnswers")
  questions Question[]
    groupsAdmin Group[] @relation("GroupAdmin")
    groupMemberships GroupMember[]
    claimedJuz KhatmJuz[]
    dhikrContributions DhikrContribution[]
}

enum LiveSessionType {
  DHIKR
  YASEEN
  KHATM
}

enum LiveSessionStatus {
  OPEN
  ACTIVE
  COMPLETED
}

model LiveSession {
  id           String   @id @default(uuid())
  type         LiveSessionType
  title        String
  targetCount  Int
  currentCount Int @default(0)
  status       LiveSessionStatus @default(OPEN)
  participants SessionParticipant[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SessionParticipant {
  id           String   @id @default(cuid())
  userId       String
  sessionId    String
  joinedAt     DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
  session      LiveSession @relation(fields: [sessionId], references: [id])
}

model Question {
  id         String   @id @default(cuid())
  userId     String
  content    String
  isAnswered Boolean @default(false)
  createdAt  DateTime @default(now())
  answers    Answer[]

  user       User     @relation(fields: [userId], references: [id])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  scholarId  String
  content    String
  createdAt  DateTime @default(now())

  question   Question @relation(fields: [questionId], references: [id])
  scholar    User     @relation("ScholarAnswers", fields: [scholarId], references: [id])
}

model QuranMedia {
  id               String   @id @default(uuid())
  // Removed invalid relation to AwradChapter
  // If QuranMedia needs to reference a chapter, add a proper relation in both models
  ayahStart       Int?
  ayahEnd         Int?
  language        String?
  durationSeconds Int?
  tags            String[]
  source          String?
  license         String?
  notes           String?
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LearningResource {
  id            String   @id @default(cuid())
  title         String
  description   String?
  type          String
  url           String
  coverImageUrl String?
  author        String?
  language      String?
  pageCount     Int?
  tags          String[]
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LearningQuestion {
  id             String   @id @default(cuid())
  userId         String
  userName       String
  question       String
  aiAnswer       String?
  approvedAnswer String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  }

model HalalFoodItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  isHalal     Boolean @default(true)
  source      String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Book {
  id            String   @id @default(cuid())
  title         String
  author        String
  coverImageUrl String
  pdfFileUrl    String
  category      String
  createdAt     DateTime @default(now())
  bookmarks     Bookmark[]
}

model Recipe {
  id           String   @id @default(cuid())
  title        String
  description  String
  imageUrl     String
  ingredients  Json     // Array of strings
  instructions Json     // Array of strings
  prepTime     String
  createdAt    DateTime @default(now())
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  bookId     String
  pageNumber Int
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])
}
